PROGRAM cgVarParamArraySwap;
TYPE
    IntArray = ARRAY [1..3] OF INTEGER;
VAR
    a: IntArray;

PROCEDURE swap(VAR x: INTEGER; VAR y: INTEGER);
VAR
    t: INTEGER;
BEGIN
    t := x;
    x := y;
    y := t
END;

BEGIN
    a[1] := 9;
    a[2] := 1;
    a[3] := 5;

    CALL swap(a[1], a[2]);
    IF a[2] > a[3] THEN
        CALL swap(a[2], a[3])
    FI;

    WRITE(a[1]);
    WRITE(a[2]);
    WRITE(a[3])
END.
